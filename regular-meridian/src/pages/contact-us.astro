---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>Contact Us - 16-0 Play</title>
    <meta name="description" content="Contact the 16-0play team. Reach out for support, feedback, or inquiries regarding our cricket simulator." />
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-white selection:bg-yellow-500/30">
    <div class="max-w-4xl mx-auto px-6 py-16">
      <h1 class="text-4xl font-bold mb-8 text-yellow-500">Contact Us</h1>
      <div class="space-y-6 text-gray-300 leading-relaxed">
        <p>We'd love to hear from you! Whether you have a question about the game, feedback to improve the simulation, or just want to share your perfect 16-0 season with us, feel free to reach out.</p>
        
        <div class="bg-gray-900/50 p-6 rounded-lg border border-gray-800/50 mt-8">
          <h2 class="text-2xl font-bold text-white mb-4">Get In Touch</h2>
          <p class="mb-4">You can contact us via email for support, business inquiries, or general questions:</p>
          <a href="mailto:support@16-0play.com" class="text-yellow-500 hover:text-yellow-400 font-semibold text-lg transition-colors">
            support@16-0play.com
          </a>
        </div>
        
        <h2 class="text-2xl font-bold text-white mt-8">Follow Us</h2>
        <p>Stay updated with the latest news, updates, and leaderboard highlights by following us on social media.</p>
        <p>(Social links coming soon!)</p>
      </div>
      <div class="mt-12">
        <a href="/" class="inline-flex items-center text-yellow-500 hover:text-yellow-400 font-semibold transition-colors">
          &larr; Back to Home
        </a>
      </div>
    </div>
  </body>
</html>
